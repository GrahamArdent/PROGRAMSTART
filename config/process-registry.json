        "scripts": [
          "scripts/programstart_step_guide.py",
          "scripts/programstart_validate.py",
          "scripts/programstart_checklist_progress.py"
        ],
        "prompts": [
          ".github/prompts/start-programstart-project.prompt.md",
          ".github/prompts/programstart-stage-guide.prompt.md"
        ]
      },
      "feasibility": {
        "description": "Validate whether the idea is technically and commercially viable before committing resources.",
        "files": [
          "PROGRAMBUILD/FEASIBILITY.md",
          "PROGRAMBUILD/DECISION_LOG.md",
          "PROGRAMBUILD/PROGRAMBUILD_CHECKLIST.md"
        ],
        "scripts": [
          "scripts/programstart_validate.py",
          "scripts/programstart_step_guide.py"
        ],
        "prompts": [
          ".github/prompts/programstart-stage-guide.prompt.md"
        ]
      },
      "research": {
