  "repo_boundary_policy": {
    "enabled": true,
    "docs": [
      {
        "path": ".github/copilot-instructions.md",
        "must_contain": [
          "Repository boundary is explicit: do not inspect, edit, stage, commit, or push another repository unless the user explicitly names that repository and asks for that action.",
          "If the task may require work in another repository, stop and ask for express consent before proceeding."
        ]
      },
      {
        "path": "PROGRAMBUILD/PROGRAMBUILD.md",
        "must_contain": [
          "repo-boundary consent rule for AI-assisted work: do not inspect, edit, stage, commit, or push another repository unless the user explicitly names it and asks for that action",
          "Repository scope is explicit in AI-assisted workflows: keep work inside the current repo unless the user explicitly names another repo and asks for that action."
        ]
      },
      {
        "path": "QUICKSTART.md",
        "must_contain": [
          "Repo boundary rule: PROGRAMSTART work stays inside this repo unless the user explicitly names another repo and asks you to work there.",
          ".\\scripts\\pb.ps1 validate --check repo-boundary # cross-repo consent rule still enforced"
        ]
      }
    ]
  },
