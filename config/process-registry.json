  "sync_rules": [
    {
      "name": "programbuild_control_inventory",
      "system": "programbuild",
      "authority_files": [
        "PROGRAMBUILD/PROGRAMBUILD_CANONICAL.md",
        "PROGRAMBUILD/PROGRAMBUILD_FILE_INDEX.md"
      ],
      "dependent_files": [
        "PROGRAMBUILD/PROGRAMBUILD.md",
        "PROGRAMBUILD/PROGRAMBUILD_LITE.md",
        "PROGRAMBUILD/PROGRAMBUILD_PRODUCT.md",
        "PROGRAMBUILD/PROGRAMBUILD_ENTERPRISE.md",
        "PROGRAMBUILD/PROGRAMBUILD_ADR_TEMPLATE.md",
        "PROGRAMBUILD/PROGRAMBUILD_KICKOFF_PACKET.md",
        "PROGRAMBUILD/PROGRAMBUILD_SUBAGENTS.md",
        "PROGRAMBUILD/PROGRAMBUILD_CHECKLIST.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "Changes to Program Build control behavior should update the canonical and file index docs in the same change."
    },
    {
      "name": "programbuild_architecture_contracts",
      "system": "programbuild",
      "authority_files": [
        "PROGRAMBUILD/ARCHITECTURE.md"
      ],
      "dependent_files": [
        "PROGRAMBUILD/TEST_STRATEGY.md",
        "PROGRAMBUILD/RELEASE_READINESS.md",
        "PROGRAMBUILD/RISK_SPIKES.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "Test strategy, release readiness, and risk spikes depend on architecture contracts. Update ARCHITECTURE.md first when contracts change."
    },
    {
      "name": "programbuild_requirements_scope",
      "system": "programbuild",
      "authority_files": [
        "PROGRAMBUILD/REQUIREMENTS.md"
      ],
      "dependent_files": [
        "PROGRAMBUILD/USER_FLOWS.md",
        "PROGRAMBUILD/ARCHITECTURE.md",
        "PROGRAMBUILD/TEST_STRATEGY.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "User flows, architecture, and test strategy must stay aligned with requirements scope. Update REQUIREMENTS.md first when scope changes."
    },
    {
      "name": "programbuild_feasibility_cascade",
      "system": "programbuild",
      "authority_files": [
        "PROGRAMBUILD/FEASIBILITY.md"
      ],
      "dependent_files": [
        "PROGRAMBUILD/DECISION_LOG.md",
        "PROGRAMBUILD/RESEARCH_SUMMARY.md",
        "PROGRAMBUILD/REQUIREMENTS.md",
        "PROGRAMBUILD/RISK_SPIKES.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "Feasibility outcomes, kill criteria, and early risk framing should be updated before downstream decision records, research, scope, and spike plans drift."
    },
    {
      "name": "programbuild_variant_alignment",
      "system": "programbuild",
      "authority_files": [
        "PROGRAMBUILD/PROGRAMBUILD.md"
      ],
      "dependent_files": [
        "PROGRAMBUILD/PROGRAMBUILD_LITE.md",
        "PROGRAMBUILD/PROGRAMBUILD_PRODUCT.md",
        "PROGRAMBUILD/PROGRAMBUILD_ENTERPRISE.md"
      ],
      "require_authority_when_dependents_change": false,
      "description": "Variant playbooks should stay compatible with the master playbook stage order and naming rules. Review PROGRAMBUILD.md when variants change."
    },
    {
      "name": "userjourney_external_review_packet",
      "system": "userjourney",
      "authority_files": [
        "USERJOURNEY/OPEN_QUESTIONS.md",
        "USERJOURNEY/LEGAL_REVIEW_NOTES.md",
        "USERJOURNEY/LEGAL_AND_CONSENT.md"
      ],
      "dependent_files": [
        "USERJOURNEY/EXTERNAL_REVIEW_PACKET.md",
        "USERJOURNEY/TERMS_OF_SERVICE_DRAFT.md",
        "USERJOURNEY/PRIVACY_POLICY_DRAFT.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "External legal and operational review framing must stay aligned with the open questions, legal notes, and consent authority docs."
    },
    {
      "name": "userjourney_route_state_logic",
      "system": "userjourney",
      "authority_files": [
        "USERJOURNEY/DECISION_LOG.md",
        "USERJOURNEY/ROUTE_AND_STATE_FREEZE.md",
        "USERJOURNEY/STATES_AND_RULES.md"
      ],
      "dependent_files": [
        "USERJOURNEY/USER_FLOWS.md",
        "USERJOURNEY/SCREEN_INVENTORY.md",
        "USERJOURNEY/IMPLEMENTATION_PLAN.md",
        "USERJOURNEY/IMPLEMENTATION_TRACKER.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "Route or state behavior changes must update the decision and route/state authority docs before dependent execution docs."
    },
    {
      "name": "userjourney_legal_consent_behavior",
      "system": "userjourney",
      "authority_files": [
        "USERJOURNEY/DECISION_LOG.md",
        "USERJOURNEY/LEGAL_AND_CONSENT.md"
      ],
      "dependent_files": [
        "USERJOURNEY/TERMS_OF_SERVICE_DRAFT.md",
        "USERJOURNEY/PRIVACY_POLICY_DRAFT.md",
        "USERJOURNEY/LEGAL_REVIEW_NOTES.md",
        "USERJOURNEY/UX_COPY_DRAFT.md",
        "USERJOURNEY/ACCEPTANCE_CRITERIA.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "Legal or consent behavior changes must update the authority docs before drafts, copy, and acceptance criteria."
    },
    {
      "name": "userjourney_ux_surfaces_copy",
      "system": "userjourney",
      "authority_files": [
        "USERJOURNEY/SCREEN_INVENTORY.md",
        "USERJOURNEY/USER_FLOWS.md",
        "USERJOURNEY/UX_COPY_DRAFT.md"
      ],
      "dependent_files": [
        "USERJOURNEY/ACCEPTANCE_CRITERIA.md",
        "USERJOURNEY/ANALYTICS_AND_OUTCOMES.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "UX surface changes should update inventory, flows, and copy before downstream acceptance and analytics docs."
    },
    {
      "name": "userjourney_implementation_sequence",
      "system": "userjourney",
      "authority_files": [
        "USERJOURNEY/IMPLEMENTATION_TRACKER.md"
      ],
      "dependent_files": [
        "USERJOURNEY/EXECUTION_SLICES.md",
        "USERJOURNEY/FILE_BY_FILE_IMPLEMENTATION_CHECKLIST.md",
        "USERJOURNEY/DELIVERY_GAMEPLAN.md"
      ],
      "require_authority_when_dependents_change": true,
      "description": "Implementation sequence changes must start in the tracker and then flow to slices, file checklist, and delivery gameplan."
    },
    {
      "name": "cross_system_isolation",
      "system": "cross",
      "authority_files": [],
      "dependent_files": [],
      "require_authority_when_dependents_change": false,
      "description": "PROGRAMBUILD and USERJOURNEY are separate systems. USERJOURNEY may be absent because it is an optional project attachment. Changes inside one system should not silently alter the other. If a cross-system change is needed, update both systems explicitly and note the dependency in config/process-registry.json."
    }
  ],
  "metadata_rules": {
    "required_prefixes": [
      "Purpose:",
      "Owner:",
      "Last updated:",
      "Depends on:",
      "Authority:"
