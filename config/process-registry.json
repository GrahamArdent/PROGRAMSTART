        ".ruff_cache",
        ".mypy_cache",
        ".nox",
        ".tmp_dist_smoke",
        "__pycache__",
        "build",
        "dist",
        "outputs"
      ],
      "exclude_names": [
        "PROGRAMSTART_2026-03-27.zip"
      ],
      "exclude_globs": [
        "MANIFEST_*.txt",
        "VERIFICATION_REPORT_*.md",
        "*.pyc"
      ]
    },
    "baselines": [
      {
        "name": "programbuild_backup_snapshot",
        "system": "programbuild",
        "kind": "snapshot",
        "root": "BACKUPS/2026-03-27_pre-structure_flat_export_snapshot"
