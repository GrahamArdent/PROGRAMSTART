{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://programstart.local/schemas/programbuild-state.schema.json",
  "title": "PROGRAMBUILD workflow state",
  "type": "object",
  "required": ["system", "active_stage", "stages", "variant"],
  "properties": {
    "system": { "const": "programbuild" },
    "variant": { "type": "string" },
    "active_stage": { "type": "string" },
    "stages": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/workflowEntry"
      }
    }
  },
  "$defs": {
    "signoff": {
      "type": "object",
      "required": ["decision", "date", "notes"],
      "properties": {
        "decision": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "commit_hash": {
          "type": "string",
          "description": "SHA of the HEAD commit at the time this signoff was recorded."
        }
      },
      "additionalProperties": true
    },
    "workflowEntry": {
      "type": "object",
      "required": ["status", "signoff"],
      "properties": {
        "status": { "enum": ["planned", "in_progress", "completed", "blocked"] },
        "signoff": { "$ref": "#/$defs/signoff" },
        "challenge_gate": { "$ref": "#/$defs/challengeGate" },
        "signoff_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/signoff" }
        }
      },
      "additionalProperties": true
    },
    "challengeGate": {
      "type": "object",
      "required": ["source", "from_stage", "date", "proceed", "result", "notes", "checks"],
      "properties": {
        "source": { "type": "string" },
        "from_stage": { "type": "string" },
        "to_stage": { "type": "string" },
        "date": { "type": "string" },
        "proceed": { "enum": ["yes", "conditional", "no", ""] },
        "result": { "enum": ["clear", "warning", "blocked"] },
        "notes": { "type": "string" },
        "checks": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
