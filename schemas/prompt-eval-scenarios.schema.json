{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://programstart.local/schemas/prompt-eval-scenarios.schema.json",
  "title": "Prompt evaluation scenarios",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "product_shape",
          "needs",
          "regulated",
          "attach_userjourney",
          "expected_variant",
          "expected_attach_userjourney",
          "expected_stacks",
          "required_prompt_terms",
          "required_plan_sections",
          "expected_starter_root",
          "expected_starter_files",
          "required_starter_terms"
        ],
        "properties": {
          "name": { "type": "string" },
          "product_shape": { "type": "string" },
          "needs": { "type": "array", "items": { "type": "string" } },
          "regulated": { "type": "boolean" },
          "attach_userjourney": { "type": ["boolean", "null"] },
          "expected_variant": { "type": "string" },
          "expected_attach_userjourney": { "type": "boolean" },
          "expected_stacks": { "type": "array", "items": { "type": "string" } },
          "required_prompt_terms": { "type": "array", "items": { "type": "string" } },
          "required_prompt_sections": { "type": "array", "items": { "type": "string" } },
          "required_plan_sections": { "type": "array", "items": { "type": "string" } },
          "expected_starter_root": { "type": "string" },
          "expected_starter_files": { "type": "array", "items": { "type": "string" } },
          "required_starter_terms": { "type": "array", "items": { "type": "string" } },
          "expected_services": { "type": "array", "items": { "type": "string" } },
          "expected_apis": { "type": "array", "items": { "type": "string" } },
          "expected_clis": { "type": "array", "items": { "type": "string" } },
          "expected_domains": { "type": "array", "items": { "type": "string" } },
          "expected_confidence": { "type": "string" },
          "required_warning_domains": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
