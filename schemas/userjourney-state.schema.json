{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://programstart.local/schemas/userjourney-state.schema.json",
  "title": "USERJOURNEY workflow state",
  "type": "object",
  "required": ["system", "active_phase", "phases"],
  "properties": {
    "system": { "const": "userjourney" },
    "active_phase": { "type": "string" },
    "phases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/workflowEntry"
      }
    }
  },
  "$defs": {
    "signoff": {
      "type": "object",
      "required": ["decision", "date", "notes"],
      "properties": {
        "decision": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "saved_at": { "type": "string" },
        "commit_hash": {
          "type": "string",
          "description": "SHA of the HEAD commit at the time this signoff was recorded."
        }
      },
      "additionalProperties": true
    },
    "workflowEntry": {
      "type": "object",
      "required": ["status", "signoff"],
      "properties": {
        "status": { "enum": ["planned", "in_progress", "completed", "blocked"] },
        "signoff": { "$ref": "#/$defs/signoff" },
        "signoff_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/signoff" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
